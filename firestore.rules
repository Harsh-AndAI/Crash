rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is the owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isAdmin());
      allow create: if request.auth != null && isOwner(userId);
      allow update: if isAdmin();
    }

    // Requests collection
    match /requests/{requestId} {
      allow read: if isAdmin() || (request.auth != null && isOwner(resource.data.userId));
      allow create: if true; // Allow guest creation
      allow update, delete: if isAdmin();
    }

    // Documents collection
    match /documents/{docId} {
      allow read: if request.auth != null && (isOwner(resource.data.userId) || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }
  }
}
