{
  "collections": {
    "users": {
      "description": "User profiles and roles",
      "documents": {
        "{userId}": {
          "fields": {
            "email": { "type": "string" },
            "fullName": { "type": "string" },
            "role": { "type": "string", "description": "customer or admin" },
            "createdAt": { "type": "timestamp" }
          }
        }
      }
    },
    "requests": {
      "description": "Vehicle replacement requests",
      "documents": {
        "{requestId}": {
          "fields": {
            "userId": { "type": "string" },
            "fullName": { "type": "string" },
            "mobileNumber": { "type": "string" },
            "emailAddress": { "type": "string" },
            "accidentDate": { "type": "string" },
            "accidentLocation": { "type": "string" },
            "vehicleMake": { "type": "string" },
            "vehicleModel": { "type": "string" },
            "vehicleRegistration": { "type": "string" },
            "rideshareRequired": { "type": "boolean" },
            "insuranceCompany": { "type": "string" },
            "claimNumber": { "type": "string" },
            "repairerDetails": { "type": "string" },
            "status": { "type": "string", "description": "pending, approved, rejected, vehicle_delivered, completed" },
            "createdAt": { "type": "timestamp" },
            "updatedAt": { "type": "timestamp" }
          }
        }
      }
    },
    "documents": {
      "description": "Metadata for uploaded documents",
      "documents": {
        "{docId}": {
          "fields": {
            "requestId": { "type": "string" },
            "userId": { "type": "string" },
            "type": { "type": "string", "description": "license, registration, insurance, etc." },
            "fileName": { "type": "string" },
            "fileUrl": { "type": "string" },
            "status": { "type": "string", "description": "pending_review, verified, rejected" },
            "uploadedAt": { "type": "timestamp" }
          }
        }
      }
    }
  }
}
